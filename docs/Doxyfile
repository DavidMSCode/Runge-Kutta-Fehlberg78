# Doxygen configuration for RKF78
PROJECT_NAME           = "RKF78"
PROJECT_BRIEF          = "Runge–Kutta–Fehlberg 7(8) header-only ODE solver"
OUTPUT_DIRECTORY       = docs/build
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = NO
